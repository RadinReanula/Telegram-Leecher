# From https://my.telegram.org/apps
API_ID=12345678
API_HASH=your_api_hash_here

# From @BotFather
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Comma-separated Telegram user IDs allowed to use the bot (get yours from @userinfobot)
ALLOWED_USER_IDS=123456789

# Optional overrides
SESSION_NAME=user
SESSIONS_DIR=sessions
TMP_DIR=tmp
# Bot API upload limit is 50 MB; larger files are sent via the user session
BOT_MAX_FILE_BYTES=52428800
# Files larger than this use the user session (avoids Bot API upload timeouts). Max 50 MB for bot.
BOT_UPLOAD_THRESHOLD_BYTES=20971520
BOT_REQUEST_TIMEOUT_SEC=600
# Set to false only if you are behind SSL inspection and cannot fix CA certs (not recommended)
BOT_SSL_VERIFY=true

# Job queue (keep QUEUE_WORKERS=1 unless you accept more FloodWait risk)
QUEUE_WORKERS=1
MAX_QUEUE_SIZE=50
MAX_PENDING_PER_USER=5
JOB_HISTORY_LIMIT=200
# Load your chat list on startup so private t.me/c/ links resolve (recommended)
SYNC_DIALOGS_ON_STARTUP=true
# When true, dialog sync runs in background so the bot starts polling immediately
SYNC_DIALOGS_IN_BACKGROUND=true
MAX_LINKS_PER_MESSAGE=25
STATUS_UPDATE_INTERVAL_SEC=2
# Retries after Telegram FloodWait (0 = fail immediately)
FLOODWAIT_MAX_RETRIES=1
# Overlap album download with upload of previous item (faster multi-photo albums)
ALBUM_PIPELINE=false
ALBUM_CONCURRENCY=1
# Prune finished jobs from memory every N enqueues
JOB_PRUNE_EVERY_N_ENQUEUES=10
# Byte-level download progress in status (uses thread-safe bridge)
DOWNLOAD_PROGRESS_ENABLED=true
